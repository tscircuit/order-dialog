{
	"buildCommand": "bun run build:preview",
	"outputDirectory": "dist",
	"rewrites": [
		{
			"source": "/v1/:path*",
			"destination": "/api/v1/:path*"
		},
		{
			"source": "/checkout/:path*",
			"destination": "/api/checkout/:path*"
		},
		{
			"source": "/health",
			"destination": "/api/health"
		}
	]
}
